<UserControl x:Class="Pluck.UI.Controls.BubbleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220"
             MinHeight="56"
             Cursor="Hand"
             MouseEnter="UserControl_MouseEnter"
             MouseLeave="UserControl_MouseLeave"
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown"
             MouseMove="UserControl_MouseMove"
             MouseLeftButtonUp="UserControl_MouseLeftButtonUp"
             PreviewMouseDown="UserControl_PreviewMouseDown">
    <UserControl.Resources>
        <Storyboard x:Key="HoverIn">
            <DoubleAnimation Storyboard.TargetName="ScaleRoot"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1.05" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="ScaleRoot"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1.05" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="HoverOut">
            <DoubleAnimation Storyboard.TargetName="ScaleRoot"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1" Duration="0:0:0.15"/>
            <DoubleAnimation Storyboard.TargetName="ScaleRoot"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </UserControl.Resources>
    <Border x:Name="CardBorder"
            Background="#F5FFFFFF"
            CornerRadius="12"
            Padding="10"
            BorderBrush="#33000000"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25"/>
        </Border.Effect>
        <Grid x:Name="ScaleRoot" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="SourceIcon" Grid.Column="0" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Top"/>
            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="SourceName" FontSize="11" Foreground="#666" Margin="0,0,6,0"/>
                    <TextBlock x:Name="Timestamp" FontSize="11" Foreground="#888"/>
                    <TextBlock x:Name="PinBadge" Text="📌" FontSize="11" Margin="4,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
                <TextBlock x:Name="PreviewText" TextWrapping="Wrap" FontSize="13" Margin="0,4,0,0" MaxHeight="60"/>
                <Image x:Name="PreviewImage" MaxWidth="180" MaxHeight="100" Margin="0,4,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
