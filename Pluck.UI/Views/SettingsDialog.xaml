<Window x:Class="Pluck.UI.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pluck Settings"
        Height="560"
        Width="560"
        MinHeight="400"
        MinWidth="480"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowActivated="False">
    <Border Background="#FAFAFA" CornerRadius="10" BorderBrush="#D8D8D8" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.22"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="53.96"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="10,10,0,0"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold" Foreground="#222"
                           VerticalAlignment="Center" Margin="14,0"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="12,8,12,20">
                <StackPanel>
                    <TextBlock Text="Bubble settings" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Opacity" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="OpacitySlider" Minimum="10" Maximum="90" Width="160" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OpacityLabel" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max bubbles" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox x:Name="MaxBubblesBox" Grid.Row="1" Grid.Column="1" Width="72" HorizontalAlignment="Left" Margin="0,8,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Display duration" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                            <CheckBox x:Name="DisplayDurationCheck" Content="Auto-dismiss" VerticalAlignment="Center"/>
                            <TextBox x:Name="DisplayDurationBox" Width="44" Margin="8,0,0,0"/>
                            <TextBlock Text="sec" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <CheckBox x:Name="FloatingAnimationCheck" Grid.Row="3" Grid.Column="1" Content="Floating animation" Margin="0,8,0,0"/>
                        <CheckBox x:Name="StackCollapseCheck" Grid.Row="4" Grid.Column="1" Content="Collapse stack when too many bubbles" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Collapse when count reaches" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox x:Name="StackCollapseThresholdBox" Grid.Row="5" Grid.Column="1" Width="72" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Content display" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox x:Name="ContentDisplayCombo" Grid.Row="6" Grid.Column="1" Width="180" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ShowSourceIconCheck" Grid.Row="7" Grid.Column="1" Content="Show source app icon" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ShowSourceNameCheck" Grid.Row="8" Grid.Column="1" Content="Show source app name" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ShowTimestampCheck" Grid.Row="9" Grid.Column="1" Content="Show copy timestamp" Margin="0,8,0,0"/>
                        <CheckBox x:Name="PopEffectCheck" Grid.Row="10" Grid.Column="1" Content="Pop effect on paste" Margin="0,8,0,0"/>
                    </Grid>

                    <TextBlock Text="Mouse bindings" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,8"/>
                    <TextBlock Text="Each binding requires the listed mouse button. Hold modifier keys when clicking or dragging."
                               TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="148"/>
                            <ColumnDefinition Width="148"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Click" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Drag" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Modifiers" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Left" VerticalAlignment="Center"/>
                        <ComboBox x:Name="MouseLeftClickCombo" Grid.Row="1" Grid.Column="1" Margin="0,4,6,0"/>
                        <ComboBox x:Name="MouseLeftDragCombo" Grid.Row="1" Grid.Column="2" Margin="0,4,6,0"/>
                        <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,4,0,0">
                            <CheckBox x:Name="MouseLeftCtrlCheck" Content="Ctrl" Margin="0,0,6,0"/>
                            <CheckBox x:Name="MouseLeftShiftCheck" Content="Shift" Margin="0,0,6,0"/>
                            <CheckBox x:Name="MouseLeftAltCheck" Content="Alt"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Right" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox x:Name="MouseRightClickCombo" Grid.Row="2" Grid.Column="1" Margin="0,12,6,0"/>
                        <ComboBox x:Name="MouseRightDragCombo" Grid.Row="2" Grid.Column="2" Margin="0,12,6,0"/>
                        <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox x:Name="MouseRightCtrlCheck" Content="Ctrl" Margin="0,0,6,0"/>
                            <CheckBox x:Name="MouseRightShiftCheck" Content="Shift" Margin="0,0,6,0"/>
                            <CheckBox x:Name="MouseRightAltCheck" Content="Alt"/>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Middle" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <ComboBox x:Name="MouseMiddleClickCombo" Grid.Row="3" Grid.Column="1" Margin="0,12,6,0"/>
                        <ComboBox x:Name="MouseMiddleDragCombo" Grid.Row="3" Grid.Column="2" Margin="0,12,6,0"/>
                        <StackPanel Grid.Row="3" Grid.Column="3" Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox x:Name="MouseMiddleCtrlCheck" Content="Ctrl" Margin="0,0,6,0"/>
                            <CheckBox x:Name="MouseMiddleShiftCheck" Content="Shift" Margin="0,0,6,0"/>
                            <CheckBox x:Name="MouseMiddleAltCheck" Content="Alt"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="General settings" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Global hotkey" VerticalAlignment="Center"/>
                        <TextBox x:Name="HotkeyBox" Grid.Row="0" Grid.Column="1" Width="140" HorizontalAlignment="Left" ToolTip="Format: Ctrl+Shift+V"/>
                        <CheckBox x:Name="LaunchAtStartupCheck" Grid.Row="1" Grid.Column="1" Content="Launch at Windows startup" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="History limit" VerticalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBox x:Name="HistoryLimitBox" Grid.Row="2" Grid.Column="1" Width="72" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        <CheckBox x:Name="ClearOnExitCheck" Grid.Row="3" Grid.Column="1" Content="Clear history on exit" Margin="0,8,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2" Content="Save settings" Padding="16,8" HorizontalAlignment="Right"
                    Margin="0,8,12,12" Click="SaveSettings_Click" Width="103"/>
        </Grid>
    </Border>
</Window>
