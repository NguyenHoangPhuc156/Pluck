<Window x:Class="Pluck.UI.Views.BubbleOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PluckOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        ResizeMode="NoResize">
    <Grid>
        <Canvas x:Name="BubbleCanvas" Background="Transparent"/>
        <Canvas x:Name="EffectCanvas" IsHitTestVisible="False"/>
        <Border x:Name="StackBadge"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,4,0"
                Background="#E0287070"
                CornerRadius="16"
                Padding="12,8"
                Visibility="Collapsed"
                Cursor="Hand"
                MouseLeftButtonUp="StackBadge_Click">
            <TextBlock x:Name="StackCountText" Foreground="White" FontWeight="Bold" FontSize="14"/>
        </Border>
    </Grid>
</Window>
