<Window x:Class="Pluck.UI.Views.MainDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pluck"
        Height="560"
        Width="576"
        MinHeight="400"
        MinWidth="448"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Border Background="#FAFAFA" CornerRadius="10" BorderBrush="#D8D8D8" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.22"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="10,10,0,0"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Pluck" FontSize="14" FontWeight="SemiBold" Foreground="#222" VerticalAlignment="Center"/>
                        <TextBlock Text=" — Your clipboard, alive on screen" FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="SettingsButton" Width="32" Height="32" Margin="0,0,4,0"
                                Padding="0" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                ToolTip="Settings" Click="Settings_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <Image Source="/Assets/setting.png" Width="16" Height="16"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="CloseButton" Content="✕" Width="32" Height="32" Padding="0" FontSize="14"
                                Background="Transparent" BorderThickness="0" Foreground="#555" Cursor="Hand"
                                ToolTip="Close" Click="Close_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="12,8,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="HistorySearchBox" Grid.Row="0" Margin="0,0,0,8" Padding="8,6"
                         ToolTip="Search in preview, text, and file paths" TextChanged="HistoryFilters_Changed"/>

                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="HistoryAppFilter" Grid.Column="0" Margin="0,0,6,0" SelectionChanged="HistoryFilters_Changed"/>
                    <ComboBox x:Name="HistoryTypeFilter" Grid.Column="1" Margin="0,0,6,0" SelectionChanged="HistoryFilters_Changed"/>
                    <ComboBox x:Name="HistoryTimeFilter" Grid.Column="2" Margin="0,0,6,0" SelectionChanged="HistoryFilters_Changed"/>
                    <Button Grid.Column="3" Content="Clear" Padding="10,4" Click="ClearHistoryFilters_Click"/>
                </Grid>

                <TextBlock x:Name="HistoryResultLabel" Grid.Row="2" Margin="0,0,0,6" Foreground="#666" FontSize="11"/>

                <ListView x:Name="HistoryList" Grid.Row="3" SelectionMode="Extended"
                          KeyDown="HistoryList_OnKeyDown"
                          MouseRightButtonUp="HistoryList_MouseRightButtonUp"
                          PreviewMouseRightButtonDown="HistoryList_PreviewMouseRightButtonDown">
                    <ListView.ContextMenu>
                        <ContextMenu x:Name="HistoryContextMenu" Opened="HistoryContextMenu_Opened">
                            <MenuItem x:Name="CtxPaste" Header="Paste" Click="CtxPaste_Click"/>
                            <MenuItem x:Name="CtxPin" Header="Pin" Click="CtxPin_Click"/>
                            <MenuItem x:Name="CtxCopyAgain" Header="Copy again" Click="CtxCopyAgain_Click"/>
                            <MenuItem x:Name="CtxPluck" Header="Pluck" Click="CtxPluck_Click"/>
                            <Separator/>
                            <MenuItem x:Name="CtxDelete" Header="Delete" Click="CtxDelete_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn x:Name="PinColumn" Header="" Width="0">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="/Assets/pin.png" Width="12" Height="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Type" Width="52" DisplayMemberBinding="{Binding TypeLabel}"/>
                            <GridViewColumn Header="Preview" Width="200" DisplayMemberBinding="{Binding Preview}"/>
                            <GridViewColumn Header="Source" Width="80" DisplayMemberBinding="{Binding SourceAppName}"/>
                            <GridViewColumn Header="Time" Width="68" DisplayMemberBinding="{Binding TimeLabel}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>
    </Border>
</Window>
