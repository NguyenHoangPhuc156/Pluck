<Window x:Class="Pluck.UI.Views.MainDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pluck"
        Height="560"
        Width="720"
        MinHeight="400"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Pluck — Your clipboard, alive on screen"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <TabControl Grid.Row="1" x:Name="MainTabs">
            <TabItem Header="History">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="HistoryList"
                              Grid.Row="0"
                              SelectionMode="Single"
                              KeyDown="HistoryList_OnKeyDown">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding TypeLabel}"/>
                                <GridViewColumn Header="Preview" Width="280" DisplayMemberBinding="{Binding Preview}"/>
                                <GridViewColumn Header="Source" Width="120" DisplayMemberBinding="{Binding SourceAppName}"/>
                                <GridViewColumn Header="Time" Width="100" DisplayMemberBinding="{Binding TimeLabel}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Paste" Padding="12,4" Margin="0,0,8,0" Click="Paste_Click"/>
                        <Button Content="Pin" Padding="12,4" Margin="0,0,8,0" Click="Pin_Click"/>
                        <Button Content="Copy again" Padding="12,4" Margin="0,0,8,0" Click="CopyAgain_Click"/>
                        <Button Content="Delete" Padding="12,4" Click="Delete_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Settings" x:Name="SettingsTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4">
                        <TextBlock Text="Bubble settings" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Opacity" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="OpacitySlider" Minimum="10" Maximum="90" Width="200" VerticalAlignment="Center"/>
                                <TextBlock x:Name="OpacityLabel" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Max bubbles" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox x:Name="MaxBubblesBox" Grid.Row="1" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Display duration" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox x:Name="DisplayDurationCheck" Content="Auto-dismiss" VerticalAlignment="Center"/>
                                <TextBox x:Name="DisplayDurationBox" Width="50" Margin="8,0,0,0"/>
                                <TextBlock Text="sec" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="FloatingAnimationCheck" Grid.Row="3" Grid.Column="1" Content="Floating animation" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Content display" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <ComboBox x:Name="ContentDisplayCombo" Grid.Row="4" Grid.Column="1" Width="200" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                            <CheckBox x:Name="ShowSourceIconCheck" Grid.Row="5" Grid.Column="1" Content="Show source app icon" Margin="0,8,0,0"/>
                            <CheckBox x:Name="ShowSourceNameCheck" Grid.Row="6" Grid.Column="1" Content="Show source app name" Margin="0,8,0,0"/>
                            <CheckBox x:Name="ShowTimestampCheck" Grid.Row="7" Grid.Column="1" Content="Show copy timestamp" Margin="0,8,0,0"/>
                            <CheckBox x:Name="PopEffectCheck" Grid.Row="8" Grid.Column="1" Content="Pop effect on paste" Margin="0,8,0,0"/>
                        </Grid>

                        <TextBlock Text="General settings" FontWeight="SemiBold" FontSize="14" Margin="0,8,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Global hotkey" VerticalAlignment="Center"/>
                            <TextBox x:Name="HotkeyBox" Grid.Row="0" Grid.Column="1" Width="160" HorizontalAlignment="Left" ToolTip="Format: Ctrl+Shift+V"/>
                            <CheckBox x:Name="LaunchAtStartupCheck" Grid.Row="1" Grid.Column="1" Content="Launch at Windows startup" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="History limit" VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBox x:Name="HistoryLimitBox" Grid.Row="2" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                            <CheckBox x:Name="ClearOnExitCheck" Grid.Row="3" Grid.Column="1" Content="Clear history on exit" Margin="0,8,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save settings" Padding="14,6" Margin="0,0,8,0" Click="SaveSettings_Click"/>
            <Button Content="Close" Padding="14,6" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
